      "select_blocks": [
        {
          "tables": [
            "USR_FCT_CONTRATO_PERSONA\n            GROUP BY PERSONA_ID"
          ],
          "columns": [
            "PERSONA_ID",
            "CONTRATO_ID",
            "SUMIMPORTE_MENSUAL"
          ],
          "snippet": "SELECT\n                persona_id,\n                COUNT(DISTINCT contrato_id) AS num_contratos,\n                SUM(importe_mensual)        AS importe_total\n            FROM usr_fct_contrato_persona\n            GROUP BY persona_id"
        },
        {
          "tables": [
            "USR_FCT_CONTRATO_PERSONA\n            GROUP BY TIPO_PRODUCTO"
          ],
          "columns": [
            "TIPO_PRODUCTO",
            "CONTRATO_ID",
            "SUMIMPORTE_MENSUAL"
          ],
          "snippet": "SELECT\n                tipo_producto,\n                COUNT(DISTINCT contrato_id) AS num_contratos,\n                SUM(importe_mensual)        AS importe_total\n            FROM usr_fct_contrato_persona\n            GROUP BY tipo_producto"
        }
      ]
    },
